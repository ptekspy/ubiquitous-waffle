# Optional. Used for the first public Reddit JSON request attempt.
# Reddit generally prefers a clear platform:app:version style user-agent.
REDDIT_USER_AGENT="web:paidpolitely.reddit-analytics:v0.1.1 (by /u/ptekspy)"

# Optional. Used only as a fallback for public JSON requests that reject the API-style user-agent.
REDDIT_BROWSER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36"

# Optional. Set to 1 locally to print failed Reddit fetch attempts to the dev server console.
REDDIT_DEBUG="0"
